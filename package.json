{
  "name": "otaku-hunter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Otaku Hunter — a Vampire Survivors-style auto-battler that teaches Japanese on the level-up screen.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "smoke": "vite build && node scripts/smoke.mjs",
    "audio": "npx -y tsx tools/generate-audio.ts",
    "audio:speakers": "npx -y tsx tools/generate-audio.ts --list-speakers"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
